namespace main
func fibonacci(int n) int{
    if n <= 1 return n
    int[n+1] arr
    arr[0] = 0
    arr[1] = 1
    for int i = 2; i<=n; i = i+1{
        arr[i] = arr[i-1] + arr[i-2]
      }
    return arr[n]
  }
func main(){
    for true {
        print("Number: ")
        string input = read()
        if input == "exit" {
            exit(0)
        }
        int n = StringToInt(input)
        print(n, "th number of fibonacci sequence is ",fibonacci(n), "\n")
    }
}