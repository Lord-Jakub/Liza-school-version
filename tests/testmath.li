namespace main

import "math"
func main(){
    print("abs(5)=", math.abs(5), "\n")
    print("abs(-5)=", math.abs(-5), "\n")
    print("absf(5.5)=", math.absf(5.5), "\n")
    print("absf(-5.5)=", math.absf(-5.5), "\n")
    print("min(1, 2) =", math.min(1, 2), "\n")
    print("minf(1.1, 2.2) =", math.minf(1.1, 2.2), "\n")
    print("max(1, 2) =", math.max(1, 2), "\n")
    print("maxf(1.1, 2.2) =", math.maxf(1.1, 2.2), "\n")
    print("clamp(1, 2, 5) =", math.clamp(1, 2, 5), "\n")
    print("clamp(3, 2, 5) =", math.clamp(3, 2, 5), "\n")
    print("clamp(6, 2, 5) =", math.clamp(6, 2, 5), "\n")
    print("clampf(1.1, 2.2, 5.5) =", math.clampf(1.1, 2.2, 5.5), "\n")
    print("clampf(3.3, 2.2, 5.5) =", math.clampf(3.3, 2.2, 5.5), "\n")
    print("clampf(6.6, 2.2, 5.5) =", math.clampf(6.6, 2.2, 5.5), "\n")
    print("factorial(5)=", math.factorial(5), "\n")
    print("gcd(268, 201)=", math.gcd(268, 201), "\n")
    print("lcm(3, 23)=", math.lcm(3, 23), "\n")
    print("PI=", math.PI, "\n")
    print("sin(PI)=", math.sin(math.PI), "\n")
    print("cos(PI)=", math.cos(math.PI), "\n")
}